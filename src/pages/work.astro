---
import PageLayout from '../layouts/PageLayout.astro';
import { getEntry } from 'astro:content';

const work = await getEntry('work', 'work');
const { Content } = await work.render();
---

<PageLayout
  title="Work - Ramy Ghorayeb"
  description="Professional Experience and Work History"
>
  <div class="fade-in">
    <!-- Page Title -->
    <h1 class="text-4xl md:text-5xl font-bold mb-16">Work</h1>

    <!-- Work Experience Section -->
    <section class="max-w-2xl">
      <p class="text-lg leading-relaxed mb-8 text-secondary">
        <a href="/contact" class="hover:underline text-link">Contact me</a> if you want to know more.
      </p>
      <div class="work-content">
        <Content />
      </div>
    </section>
  </div>
</PageLayout>

<style is:global>
  /* Work content styling - matches original design */
  .work-content h2 {
    font-size: 1.5rem;
    font-weight: 600;
    margin-bottom: 2rem;
    margin-top: 0;
    color: var(--color-text);
  }

  .work-content h2:not(:first-child) {
    margin-top: 4rem;
  }

  .work-content p {
    font-size: 1.125rem;
    line-height: 1.75;
    color: var(--color-text-secondary);
    margin-bottom: 1rem;
  }

  .work-content strong {
    color: var(--color-text) !important;
    font-weight: 600;
  }

  .work-content a {
    color: var(--color-link);
  }

  .work-content a:hover {
    text-decoration: underline;
  }
</style>
