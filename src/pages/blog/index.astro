---
import { getCollection } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';

// Get all blog posts and sort by date (newest first)
const allPosts = await getCollection('blog');

// Define desired post order (most recent first)
const postOrder = [
  'drones-vs-democracy',
  'cost-to-produce-to-zero',
  'legacy-vs-ai-native-companies',
  'your-brain-was-the-bottleneck',
  'ai-will-make-us-dumber'
];

const blogPosts = allPosts
  .filter(post => !post.data.draft)
  .sort((a, b) => {
    const indexA = postOrder.indexOf(a.slug);
    const indexB = postOrder.indexOf(b.slug);
    return indexA - indexB;
  });
---

<PageLayout
  title="Blog - Ramy Ghorayeb"
  description="Thoughts and essays on AI, technology, and the future"
>
  <div class="fade-in blog-list">
    <!-- Page Title -->
    <h1 class="text-4xl md:text-5xl font-bold mb-4">Blog</h1>

    <!-- Subscription Section -->
    <div class="mb-16 space-y-4">
      <!-- RSS Link -->
      <a href="/blog/rss.xml" class="text-sm font-mono hover:underline text-secondary" target="_blank" rel="noopener noreferrer">
        Subscribe via RSS
      </a>

      <!-- Success Message (hidden by default, shown via JS when ?subscribed=true) -->
      <div id="subscription-success" class="hidden max-w-md p-4 rounded-lg bg-[var(--color-hover)] border border-default">
        <p class="text-sm text-primary font-medium">
          Thanks for subscribing! You'll receive new posts directly in your inbox.
        </p>
      </div>

      <!-- Email Subscription Form (Kit/ConvertKit) -->
      <form
        id="subscription-form"
        action="https://app.kit.com/forms/9146732/subscriptions"
        method="post"
        data-sv-form="9146732"
        data-uid="7f83354472"
        data-format="inline"
        data-version="5"
        data-options='{"settings":{"after_subscribe":{"action":"redirect","redirect_url":"https://ramyg.vercel.app/blog?subscribed=true"}}}'
        class="seva-form formkit-form flex gap-2 max-w-md"
      >
        <input
          type="email"
          name="email_address"
          placeholder="you@example.com"
          required
          class="formkit-input flex-1 px-4 py-2 border rounded-lg focus:outline-none form-input text-sm"
        />
        <button
          type="submit"
          data-element="submit"
          class="formkit-submit px-6 py-2 text-white rounded-lg font-medium font-mono text-sm transition-all duration-200 bg-[var(--color-accent)] shadow-[var(--shadow-sm)] hover:bg-[var(--color-text)] hover:shadow-[var(--shadow-md)]"
        >
          Subscribe via email
        </button>
      </form>
    </div>

    <!-- Blog Posts List -->
    <section class="max-w-2xl">
      <div class="space-y-4">
        {blogPosts.map((post) => (
          <article class="border-b pb-4 border-default">
            <a href={`/blog/${post.slug}`} class="block group">
              <h2 class="text-lg font-semibold group-hover:underline text-primary">
                {post.data.title}
              </h2>
              <time class="text-sm text-secondary">
                {post.data.date}
              </time>
            </a>
          </article>
        ))}

        <!-- External Archive Links -->
        <article class="border-b pb-4 border-default">
          <a href="https://drive.google.com/drive/folders/1NwDriCu5_SupUEnB3GHi92BZaHF0pXoV?usp=drive_link" target="_blank" rel="noopener noreferrer" class="block group">
            <h2 class="text-lg font-semibold group-hover:underline text-primary">
              Civic tech
            </h2>
            <time class="text-sm text-secondary">
              2018 <span class="text-secondary">(Google drive link)</span>
            </time>
          </a>
        </article>

        <article class="border-b pb-4 border-default">
          <a href="https://drive.google.com/drive/folders/16kztSKtpdULc-24rJgf8cY4VU55M0AtS?usp=drive_link" target="_blank" rel="noopener noreferrer" class="block group">
            <h2 class="text-lg font-semibold group-hover:underline text-primary">
              Old tech blog
            </h2>
            <time class="text-sm text-secondary">
              2017 <span class="text-secondary">(Google drive link)</span>
            </time>
          </a>
        </article>
      </div>
    </section>
  </div>
</PageLayout>

<!-- Kit (ConvertKit) form handler script -->
<script src="https://f.convertkit.com/ckjs/ck.5.js"></script>

<script>
  // Check if user just subscribed and toggle visibility
  const params = new URLSearchParams(window.location.search);
  if (params.get('subscribed') === 'true') {
    const form = document.getElementById('subscription-form');
    const success = document.getElementById('subscription-success');
    if (form) form.classList.add('hidden');
    if (success) success.classList.remove('hidden');
  }
</script>

<style is:global>
  /* Override lowercase for blog list titles and form */
  .blog-list h2,
  .blog-list time,
  .blog-list input,
  .blog-list button {
    text-transform: none !important;
  }
</style>
